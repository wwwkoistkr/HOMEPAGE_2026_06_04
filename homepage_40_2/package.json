{
  "name": "koist-website",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name koist-website",
    "dev:sandbox": "wrangler pages dev dist --d1=koist-production --local --ip 0.0.0.0 --port 3000",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply koist-production --local",
    "db:seed": "wrangler d1 execute koist-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console": "wrangler d1 execute koist-production --local",
    "db:init-admin": "node scripts/init-admin.cjs",
    "db:init-admin:local": "node scripts/init-admin.cjs --local"
  },
  "dependencies": {
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
